{
  "name": "rmi-file-server",
  "version": "1.0.0",
  "description": "MCP server providing Claude with read-only access to RMI's P:\\ share drive",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
