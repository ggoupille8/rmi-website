# WIP Sync Agent Configuration

# Path to the WIP Excel files folder
WIP_WATCH_PATH=P:\WIP - Financial

# API endpoint (production)
WIP_API_URL=https://rmi-llc.net/api/admin/wip-upload

# API key for admin authentication (get from Vercel env vars or set ADMIN_API_KEY)
WIP_API_KEY=your-api-key-here

# Debounce delay in ms (how long to wait after file change before uploading)
WIP_DEBOUNCE_MS=5000

# Log directory
WIP_LOG_DIR=./logs

# Enable debug logging
WIP_DEBUG=false
