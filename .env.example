# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local or any file with real secrets

# SendGrid API Key (required)
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# Email Configuration (optional - defaults shown)
# Email address to receive quote submissions
QUOTE_TO_EMAIL=fab@rmi-llc.net

# Email address to send from (must be verified in SendGrid)
QUOTE_FROM_EMAIL=no-reply@rmi-llc.net

# Vercel Postgres (automatically provided by Vercel in production)
# For local development, you may need to set this if using Vercel Postgres locally
POSTGRES_URL=
DATABASE_URL=
POSTGRES_PRISMA_URL=

# Admin API key (required for admin API endpoints)
ADMIN_API_KEY=

# Admin panel auth (required for browser-based admin UI)
# Generate hash: node -e "require('bcryptjs').hash('YOUR_PASSWORD', 10).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=

# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_JWT_SECRET=

# Vercel Blob storage (required for media management)
# Auto-provisioned when Blob is enabled in Vercel Dashboard → Storage → Create → Blob
BLOB_READ_WRITE_TOKEN=

# Anthropic API — used for lead enrichment and company verification
# Add to Vercel Dashboard → Project Settings → Environment Variables
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend email delivery (used for lead notification emails)
# Set to leads@rmi-llc.net after Resend domain verification
# Falls back to onboarding@resend.dev until domain is verified
RESEND_FROM_EMAIL=onboarding@resend.dev

# Base URL for verification scripts (optional)
BASE_URL=http://localhost:4321