---
import { companyName } from '../../content/site';
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background-color: transparent; backdrop-filter: none; -webkit-backdrop-filter: none; border-bottom: 1px solid transparent; box-shadow: none;"
  role="banner"
>
  <nav class="container-custom flex items-center justify-between h-12 sm:h-14 !px-2" aria-label="Main navigation">
    <!-- Left: Logo + Company name -->
    <a href="/" class="flex items-center gap-3 group shrink-0" aria-label={`${companyName} — go to top`}>
      <!--
        Logo: public/images/logo/rmi-logo-mark.png (black text on transparent bg).
        The "brightness-0 invert" filter renders it white against the dark navbar.
        If the file is missing, the onerror fallback shows the "RMI" text square.
      -->
      <picture>
        <source srcset="/images/logo/rmi-logo-mark-200.webp" type="image/webp" />
        <img
          id="navbar-logo"
          src="/images/logo/rmi-logo-mark-200.png"
          alt={`${companyName} logo`}
          width="85"
          height="48"
          loading="eager"
          decoding="sync"
          class="h-10 sm:h-12 w-auto brightness-0 invert"
          onerror="this.onerror=null;this.style.display='none';document.getElementById('navbar-logo-fallback').style.display='flex';"
        />
      </picture>
      <!-- Fallback: shown when logo file is missing -->
      <span
        id="navbar-logo-fallback"
        class="items-center justify-center w-9 h-9 rounded bg-accent-500 text-white font-bold text-sm select-none"
        style="display: none;"
        aria-hidden="true"
      >
        RMI
      </span>
      <span class="hidden sm:inline text-base font-bold text-white tracking-wide group-hover:text-accent-300 transition-colors">
        {companyName}
      </span>
    </a>

    <!-- Right: Desktop links -->
    <div class="hidden md:flex items-center gap-4 lg:gap-6">
      <a
        href="#services"
        data-nav-section="services"
        class="nav-link text-sm font-medium text-neutral-200 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-400 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent rounded px-2 py-2 min-h-[44px] inline-flex items-center"
      >
        Services
      </a>
      <a
        href="#about"
        data-nav-section="about"
        class="nav-link text-sm font-medium text-neutral-200 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-400 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent rounded px-2 py-2 min-h-[44px] inline-flex items-center"
      >
        About
      </a>
      <a
        href="#projects"
        data-nav-section="projects"
        class="nav-link text-sm font-medium text-neutral-200 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-400 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent rounded px-2 py-2 min-h-[44px] inline-flex items-center"
      >
        Projects
      </a>
      <a
        href="#contact"
        data-nav-section="contact"
        class="nav-link text-sm font-medium text-neutral-200 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-400 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent rounded px-2 py-2 min-h-[44px] inline-flex items-center"
      >
        Contact
      </a>
      <a
        href="#contact"
        class="btn-primary px-5 py-2.5 text-sm min-h-[44px] transition-all duration-200 ease-in-out"
      >
        Request a Quote
      </a>
    </div>

    <!-- Mobile hamburger button -->
    <button
      id="menu-toggle"
      type="button"
      class="md:hidden relative z-10 flex items-center justify-center w-11 h-11 rounded-md text-white hover:bg-white/10 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-400 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open navigation menu"
    >
      <!-- Hamburger icon (shown when closed) -->
      <svg id="icon-open" class="w-6 h-6 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <!-- Close icon (shown when open) -->
      <svg id="icon-close" class="w-6 h-6 hidden transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

</header>

<!-- Mobile menu overlay — outside <header> so backdrop-filter doesn't create a containing block -->
<div
  id="mobile-menu"
  class="md:hidden fixed inset-0 top-12 sm:top-14 z-[60] invisible pointer-events-none"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation"
>
  <!-- Backdrop — tap to close -->
  <div
    id="mobile-menu-backdrop"
    class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-300"
  ></div>
  <!-- Slide-in panel -->
  <div
    id="mobile-menu-panel"
    class="absolute top-0 right-0 bottom-0 w-72 translate-x-full transition-transform duration-300 ease-out bg-neutral-900/[0.97] backdrop-blur-[12px]"
  >
    <nav class="flex flex-col items-center justify-center gap-6 h-full" aria-label="Mobile navigation links">
      <a href="#services" class="mobile-nav-link text-2xl font-semibold text-neutral-300 hover:text-accent-400 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-400 rounded px-6 py-3 min-h-[48px] flex items-center border-b border-neutral-700/40 w-48 justify-center">
        Services
      </a>
      <a href="#about" class="mobile-nav-link text-2xl font-semibold text-neutral-300 hover:text-accent-400 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-400 rounded px-6 py-3 min-h-[48px] flex items-center border-b border-neutral-700/40 w-48 justify-center">
        About
      </a>
      <a href="#projects" class="mobile-nav-link text-2xl font-semibold text-neutral-300 hover:text-accent-400 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-400 rounded px-6 py-3 min-h-[48px] flex items-center border-b border-neutral-700/40 w-48 justify-center">
        Projects
      </a>
      <a href="#contact" class="mobile-nav-link text-2xl font-semibold text-neutral-300 hover:text-accent-400 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent-400 rounded px-6 py-3 min-h-[48px] flex items-center w-48 justify-center">
        Contact
      </a>
      <a
        href="#contact"
        class="mobile-nav-link mt-4 btn-primary px-8 min-h-[48px]"
      >
        Request a Quote
      </a>
    </nav>
  </div>
</div>

<style>
  /* Active nav link styling — applied via JS */
  .nav-link-active {
    color: white;
    position: relative;
  }
  .nav-link-active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0.25rem;
    right: 0.25rem;
    height: 2px;
    background: rgb(59, 130, 246); /* accent-500 */
    border-radius: 1px;
  }

  /* Active mobile nav link — applied via JS */
  .mobile-nav-link-active {
    color: rgb(96, 165, 250) !important; /* blue-400 */
    border-left: 3px solid rgb(96, 165, 250);
  }
</style>

<script>
  // ── Scroll-based background transition with hysteresis ──
  const navbar = document.getElementById('navbar');
  const FROSTED_THRESHOLD = 50;
  const TRANSPARENT_THRESHOLD = 20;
  let isFrosted = false;

  function applyFrosted() {
    if (!navbar) return;
    navbar.style.backgroundColor = 'rgba(23, 23, 23, 0.85)';
    navbar.style.backdropFilter = 'blur(12px)';
    (navbar.style as unknown as Record<string, string>)['webkitBackdropFilter'] = 'blur(12px)';
    navbar.style.borderBottom = '1px solid rgba(255, 255, 255, 0.1)';
    navbar.style.boxShadow = '0 4px 12px rgba(0, 0, 0, 0.3)';
  }

  function applyTransparent() {
    if (!navbar) return;
    navbar.style.backgroundColor = 'transparent';
    navbar.style.backdropFilter = 'none';
    (navbar.style as unknown as Record<string, string>)['webkitBackdropFilter'] = 'none';
    navbar.style.borderBottom = '1px solid transparent';
    navbar.style.boxShadow = 'none';
  }

  function updateNavbar() {
    const scrollY = window.scrollY;
    if (!isFrosted && scrollY > FROSTED_THRESHOLD) {
      isFrosted = true;
      applyFrosted();
    } else if (isFrosted && scrollY < TRANSPARENT_THRESHOLD) {
      isFrosted = false;
      applyTransparent();
    }
  }

  // Apply initial state
  if (window.scrollY > FROSTED_THRESHOLD) {
    isFrosted = true;
    applyFrosted();
  }

  window.addEventListener('scroll', updateNavbar, { passive: true });

  // ── Mobile menu toggle ──
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
  const mobileMenuPanel = document.getElementById('mobile-menu-panel');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  // Body scroll lock (iOS-safe: position:fixed with stored scroll position)
  let savedScrollY = 0;

  function lockBodyScroll() {
    savedScrollY = window.scrollY;
    document.body.style.overflow = 'hidden';
    document.body.style.position = 'fixed';
    document.body.style.top = `-${savedScrollY}px`;
    document.body.style.width = '100%';
  }

  function unlockBodyScroll() {
    document.body.style.overflow = '';
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.width = '';
    window.scrollTo(0, savedScrollY);
  }

  // Track close animation timeout to cancel if reopened quickly
  let closeTimerId: number | undefined;

  // Focus trap handler — added/removed dynamically when menu opens/closes
  function trapFocus(e: KeyboardEvent) {
    if (!mobileMenu || !menuToggle) return;
    const focusableElements = mobileMenu.querySelectorAll<HTMLElement>('a, button');
    // Include the hamburger button (close button) in the focus cycle
    const allFocusable = [menuToggle, ...Array.from(focusableElements)];
    const firstFocusable = allFocusable[0];
    const lastFocusable = allFocusable[allFocusable.length - 1];

    if (e.key === 'Tab') {
      if (e.shiftKey) {
        if (document.activeElement === firstFocusable) {
          e.preventDefault();
          lastFocusable.focus();
        }
      } else {
        if (document.activeElement === lastFocusable) {
          e.preventDefault();
          firstFocusable.focus();
        }
      }
    }
  }

  function openMenu() {
    if (!mobileMenu || !menuToggle || !iconOpen || !iconClose) return;
    // Cancel any pending close animation
    if (closeTimerId) { clearTimeout(closeTimerId); closeTimerId = undefined; }
    // Slide panel in + fade backdrop
    mobileMenu.classList.remove('invisible', 'pointer-events-none');
    mobileMenu.classList.add('visible', 'pointer-events-auto');
    mobileMenuBackdrop?.classList.remove('opacity-0');
    mobileMenuBackdrop?.classList.add('opacity-100');
    mobileMenuPanel?.classList.remove('translate-x-full');
    mobileMenuPanel?.classList.add('translate-x-0');

    iconOpen.classList.add('hidden');
    iconClose.classList.remove('hidden');
    menuToggle.setAttribute('aria-expanded', 'true');
    menuToggle.setAttribute('aria-label', 'Close navigation menu');
    lockBodyScroll();
    // Activate focus trap and move focus to first nav link
    document.addEventListener('keydown', trapFocus);
    const firstLink = mobileMenu.querySelector<HTMLElement>('.mobile-nav-link');
    firstLink?.focus();
  }

  function closeMenu() {
    if (!mobileMenu || !menuToggle || !iconOpen || !iconClose) return;
    // Start slide-out + fade-out transitions
    mobileMenuBackdrop?.classList.remove('opacity-100');
    mobileMenuBackdrop?.classList.add('opacity-0');
    mobileMenuPanel?.classList.remove('translate-x-0');
    mobileMenuPanel?.classList.add('translate-x-full');
    // Hide container after transition completes (300ms)
    closeTimerId = window.setTimeout(() => {
      mobileMenu?.classList.remove('visible', 'pointer-events-auto');
      mobileMenu?.classList.add('invisible', 'pointer-events-none');
      closeTimerId = undefined;
    }, 300);

    iconOpen.classList.remove('hidden');
    iconClose.classList.add('hidden');
    menuToggle.setAttribute('aria-expanded', 'false');
    menuToggle.setAttribute('aria-label', 'Open navigation menu');
    unlockBodyScroll();
    // Remove focus trap
    document.removeEventListener('keydown', trapFocus);
  }

  menuToggle?.addEventListener('click', () => {
    const isOpen = menuToggle.getAttribute('aria-expanded') === 'true';
    if (isOpen) {
      closeMenu();
      menuToggle.focus();
    } else {
      openMenu();
    }
  });

  const mobileLinks = mobileMenu?.querySelectorAll('.mobile-nav-link');
  mobileLinks?.forEach((link) => {
    link.addEventListener('click', () => {
      closeMenu();
      menuToggle?.focus();
    });
  });

  // Close menu when tapping the backdrop
  mobileMenuBackdrop?.addEventListener('click', () => {
    closeMenu();
    menuToggle?.focus();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuToggle?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
      menuToggle.focus();
    }
  });

  // Signal that the menu script is ready (used by Playwright tests)
  menuToggle?.setAttribute('data-ready', 'true');

  // ── Intersection Observer for active nav link highlighting ──
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('a.nav-link[data-nav-section]');
  const mobileNavLinks = document.querySelectorAll<HTMLAnchorElement>('.mobile-nav-link[href^="#"]');
  const sectionIds = ['services', 'about', 'projects', 'contact'];
  const sections = sectionIds
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => el !== null);

  // Track intersection ratios per section
  const sectionRatios = new Map<string, number>();
  let currentHash = '';

  function setActiveNav(activeId: string | null) {
    navLinks.forEach((link) => {
      const section = link.getAttribute('data-nav-section');
      if (section === activeId) {
        link.classList.add('nav-link-active');
      } else {
        link.classList.remove('nav-link-active');
      }
    });

    // Highlight active mobile nav link (exclude CTA button)
    mobileNavLinks.forEach((link) => {
      if (link.classList.contains('btn-primary')) return;
      const section = link.getAttribute('href')?.replace('#', '');
      if (section === activeId) {
        link.classList.add('mobile-nav-link-active');
      } else {
        link.classList.remove('mobile-nav-link-active');
      }
    });

    // Update URL hash without creating history entries
    const newHash = activeId ? `#${activeId}` : '';
    if (newHash !== currentHash) {
      currentHash = newHash;
      if (newHash) {
        history.replaceState(null, '', newHash);
      } else {
        // Clear hash — use pathname to avoid the bare '#'
        history.replaceState(null, '', window.location.pathname + window.location.search);
      }
    }
  }

  function updateActiveLink() {
    // Find the first section (in page order) with ≥30% visibility
    let activeId: string | null = null;
    for (const id of sectionIds) {
      if ((sectionRatios.get(id) ?? 0) >= 0.3) {
        activeId = id;
        break;
      }
    }

    // Fallback: if no section hits 30%, pick the one with the highest ratio
    if (!activeId) {
      let best = 0;
      for (const id of sectionIds) {
        const ratio = sectionRatios.get(id) ?? 0;
        if (ratio > best) {
          best = ratio;
          activeId = id;
        }
      }
      // If the best ratio is essentially zero, nothing is active (hero/top)
      if (best < 0.05) activeId = null;
    }

    setActiveNav(activeId);
  }

  if (sections.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          sectionRatios.set(entry.target.id, entry.intersectionRatio);
        });
        updateActiveLink();
      },
      {
        // Offset top by navbar height (h-14 = 56px)
        rootMargin: '-56px 0px 0px 0px',
        threshold: [0, 0.1, 0.2, 0.3, 0.5, 0.7, 1],
      }
    );

    sections.forEach((section) => observer.observe(section));
  }
</script>
