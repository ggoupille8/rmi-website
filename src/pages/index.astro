---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroFullWidth from '../components/landing/HeroFullWidth';
import Services from '../components/landing/Services';
import About from '../components/landing/About';
import MaterialsMarquee from '../components/landing/MaterialsMarquee';
import ProjectShowcase from '../components/landing/ProjectShowcase';
import CTABanner from '../components/landing/CTABanner';
import ContactForm from '../components/landing/ContactForm';
import Footer from '../components/landing/Footer';
import FloatingMobileCTA from '../components/landing/FloatingMobileCTA';
import { heroTagline, siteTitle, siteDescription } from '../content/site';
---

<BaseLayout
  title={siteTitle}
  description={siteDescription}
  canonical="https://rmi-llc.net/"
>
  <div>
    <HeroFullWidth
      client:load
      tagline={heroTagline}
    />
    <div id="services" class="scroll-mt-14">
      <Services client:visible />
    </div>
    <div class="w-full h-px bg-gradient-to-r from-transparent via-blue-500/30 to-transparent" />
    <div id="about" class="scroll-mt-14">
      <About />
    </div>
    <div class="w-full h-px bg-gradient-to-r from-transparent via-blue-500/30 to-transparent" />
    <MaterialsMarquee />
    <div class="w-full h-px bg-gradient-to-r from-transparent via-blue-500/30 to-transparent" />
    <div id="projects" class="scroll-mt-14">
      <ProjectShowcase client:visible />
    </div>
    <div class="w-full h-px bg-gradient-to-r from-transparent via-blue-500/30 to-transparent" />
    <CTABanner />
    <div class="relative overflow-hidden">
      <!-- Background image for Contact form -->
      <picture>
        <source
          srcset="/images/cta/cta-project-480w.webp 480w, /images/cta/cta-project-960w.webp 960w, /images/cta/cta-project-1920w.webp 1920w"
          sizes="100vw"
          type="image/webp"
        />
        <img
          src="/images/cta/cta-project.jpeg"
          alt=""
          width="1920"
          height="1080"
          class="absolute inset-0 w-full h-full object-cover object-[center_25%] md:object-[center_35%]"
          loading="lazy"
          decoding="async"
          aria-hidden="true"
        />
      </picture>
      <div class="absolute inset-0 bg-black/65"></div>
      <div id="contact" class="scroll-mt-14 relative">
        <ContactForm client:visible />
      </div>
    </div>
    <Footer client:visible />
    <FloatingMobileCTA client:load />
  </div>
</BaseLayout>
