---
import AdminLayout from '../../layouts/AdminLayout.astro';
import ExecutiveDashboard from '../../components/admin/ExecutiveDashboard';
import { sql } from '@vercel/postgres';
import { getPostgresEnv } from '../../lib/db-env';

export const prerender = false;

// Fetch lead stats server-side for instant render (no skeleton needed)
let leadStats = {
  total: 0,
  newCount: 0,
  contactedCount: 0,
  archivedCount: 0,
  thisWeek: 0,
  lastWeek: 0,
};
let recentLeads: Array<{ id: string; name: string; email: string; status: string; created_at: string }> = [];

let jobStats = {
  totalJobs: 0,
  needsTaxClassification: 0,
  openJobs: 0,
};

let invoiceStats = {
  totalInvoices: 0,
  totalAmount: 0,
  thisMonthCount: 0,
};

const { url: postgresUrl } = getPostgresEnv();

if (postgresUrl) {
  try {
    const [totalRes, newRes, contactedRes, archivedRes, thisWeekRes, lastWeekRes, recentRes] = await Promise.all([
      sql`SELECT COUNT(*) as count FROM contacts WHERE deleted_at IS NULL AND (category IS NULL OR category = 'lead')`,
      sql`SELECT COUNT(*) as count FROM contacts WHERE status = 'new' AND deleted_at IS NULL AND (category IS NULL OR category = 'lead')`,
      sql`SELECT COUNT(*) as count FROM contacts WHERE status = 'contacted' AND deleted_at IS NULL AND (category IS NULL OR category = 'lead')`,
      sql`SELECT COUNT(*) as count FROM contacts WHERE status = 'archived' AND deleted_at IS NULL AND (category IS NULL OR category = 'lead')`,
      sql`SELECT COUNT(*) as count FROM contacts WHERE created_at >= date_trunc('week', CURRENT_DATE) AND deleted_at IS NULL AND (category IS NULL OR category = 'lead')`,
      sql`SELECT COUNT(*) as count FROM contacts WHERE created_at >= date_trunc('week', CURRENT_DATE) - interval '7 days' AND created_at < date_trunc('week', CURRENT_DATE) AND deleted_at IS NULL AND (category IS NULL OR category = 'lead')`,
      sql`SELECT id, name, email, status, created_at FROM contacts WHERE deleted_at IS NULL ORDER BY created_at DESC LIMIT 5`,
    ]);
    leadStats = {
      total: parseInt(totalRes.rows[0]?.count || '0', 10),
      newCount: parseInt(newRes.rows[0]?.count || '0', 10),
      contactedCount: parseInt(contactedRes.rows[0]?.count || '0', 10),
      archivedCount: parseInt(archivedRes.rows[0]?.count || '0', 10),
      thisWeek: parseInt(thisWeekRes.rows[0]?.count || '0', 10),
      lastWeek: parseInt(lastWeekRes.rows[0]?.count || '0', 10),
    };
    recentLeads = recentRes.rows as typeof recentLeads;
  } catch (error) {
    console.error('Failed to fetch admin stats:', error instanceof Error ? error.message : 'Unknown error');
  }

  // Fetch job stats from jobs_master
  try {
    const [totalJobsRes, needsTaxRes, openJobsRes] = await Promise.all([
      sql`SELECT COUNT(*)::int as count FROM jobs_master WHERE is_hidden = false`,
      sql`SELECT COUNT(*)::int as count FROM jobs_master WHERE tax_status = 'unknown' AND is_hidden = false`,
      sql`SELECT COUNT(*)::int as count FROM jobs_master WHERE close_date IS NULL AND is_hidden = false`,
    ]);
    jobStats = {
      totalJobs: totalJobsRes.rows[0]?.count ?? 0,
      needsTaxClassification: needsTaxRes.rows[0]?.count ?? 0,
      openJobs: openJobsRes.rows[0]?.count ?? 0,
    };
  } catch (error) {
    console.error('Failed to fetch job stats:', error instanceof Error ? error.message : 'Unknown error');
  }

  // Fetch invoice stats
  try {
    const [totalInvRes, totalAmtRes, thisMonthRes] = await Promise.all([
      sql`SELECT COUNT(*)::int as count FROM invoices`,
      sql`SELECT COALESCE(SUM(total), 0)::numeric as total FROM invoices`,
      sql`SELECT COUNT(*)::int as count FROM invoices WHERE created_at >= date_trunc('month', CURRENT_DATE)`,
    ]);
    invoiceStats = {
      totalInvoices: totalInvRes.rows[0]?.count ?? 0,
      totalAmount: parseFloat(totalAmtRes.rows[0]?.total || '0'),
      thisMonthCount: thisMonthRes.rows[0]?.count ?? 0,
    };
  } catch (error) {
    console.error('Failed to fetch invoice stats:', error instanceof Error ? error.message : 'Unknown error');
  }
}
---

<AdminLayout title="Dashboard" subtitle="Executive overview">
  <ExecutiveDashboard
    leadStats={leadStats}
    recentLeads={recentLeads}
    jobStats={jobStats}
    invoiceStats={invoiceStats}
    client:load
  />
</AdminLayout>
