---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/landing/Footer';
import { companyName } from '../content/site';
---

<BaseLayout title={`Page Not Found | ${companyName}`}>
  <div class="relative min-h-[70vh] flex items-center justify-center px-4 bg-neutral-950">
    <!-- Decorative "404" background text -->
    <span
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[12rem] sm:text-[16rem] lg:text-[20rem] font-bold text-white/5 select-none pointer-events-none leading-none"
      aria-hidden="true"
    >
      404
    </span>

    <div class="relative z-10 text-center max-w-lg">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3">
        Page Not Found
      </h1>
      <p class="text-lg text-neutral-400 mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
        <a
          href="/"
          class="btn-primary px-6 min-h-[44px]"
        >
          Back to Home
        </a>
        <a
          href="/#contact"
          class="text-sm font-medium text-accent-400 hover:text-accent-300 transition-colors underline underline-offset-2 min-h-[44px] flex items-center"
        >
          Request a Quote
        </a>
      </div>
    </div>
  </div>
  <Footer client:visible />
</BaseLayout>
