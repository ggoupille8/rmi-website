---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/landing/Footer';
import { companyName } from '../content/site';
---

<BaseLayout title={`Page Not Found | ${companyName}`} robots="noindex, nofollow">
  <div class="relative min-h-[70vh] flex items-center justify-center px-4 bg-neutral-950 overflow-hidden">
    <!-- Animated gradient background -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute inset-0 w-[200%] bg-gradient-to-r from-neutral-950 via-blue-950/30 to-neutral-950 animate-[gradient-pan_12s_ease_infinite] will-change-transform" />
    </div>

    <!-- Decorative "404" background text -->
    <span
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[12rem] sm:text-[16rem] lg:text-[20rem] font-bold text-white/[0.03] select-none pointer-events-none leading-none"
      aria-hidden="true"
    >
      404
    </span>

    <div class="relative z-10 text-center max-w-lg">
      <picture>
        <source srcset="/images/logo/rmi-logo-full.webp" type="image/webp" />
        <img
          src="/images/logo/rmi-logo-full.png"
          alt="Resource Mechanical Insulation"
          width="200"
          height="80"
          class="h-16 w-auto mx-auto mb-6"
          style="filter: brightness(0) invert(1) drop-shadow(2px 2px 4px rgba(0,0,0,0.8));"
          loading="eager"
        />
      </picture>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-3">
        Page Not Found
      </h1>
      <p class="text-lg text-neutral-400 mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center items-center mb-10">
        <a
          href="/"
          class="btn-primary px-6 min-h-[44px]"
        >
          Back to Home
        </a>
        <a
          href="/#contact"
          class="text-sm font-medium text-accent-400 hover:text-accent-300 transition-colors underline underline-offset-2 min-h-[44px] flex items-center"
        >
          Request a Quote
        </a>
      </div>

      <!-- Quick links -->
      <div class="flex flex-wrap gap-4 justify-center text-sm">
        <a
          href="/#services"
          class="text-neutral-400 hover:text-white transition-colors min-h-[44px] flex items-center gap-1.5"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" />
          </svg>
          Services
        </a>
        <a
          href="/#about"
          class="text-neutral-400 hover:text-white transition-colors min-h-[44px] flex items-center gap-1.5"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
          </svg>
          About
        </a>
        <a
          href="/#contact"
          class="text-neutral-400 hover:text-white transition-colors min-h-[44px] flex items-center gap-1.5"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
          Contact
        </a>
      </div>
    </div>
  </div>
  <Footer client:visible />
</BaseLayout>
