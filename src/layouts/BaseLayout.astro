---
import '../styles/global.css';
import Navbar from '../components/landing/Navbar.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import { companyName, companyNameFull, email, phone, phoneE164, address, services, siteTitle, siteDescription } from '../content/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  keywords?: string;
  author?: string;
}

const {
  title = siteTitle,
  description = siteDescription,
  ogImage = '/og-image.jpg',
  ogType = 'website',
  canonical = Astro.url.href,
  keywords = 'mechanical insulation contractor, Michigan, pipe insulation, duct insulation, industrial insulation, commercial insulation, pipe support fabrication, removable insulation blankets, Detroit, southeast Michigan, Local 25',
  author = companyName,
} = Astro.props;

const fullTitle = title.includes(companyName) ? title : `${title} | ${companyName}`;
const siteUrl = Astro.site?.href || 'https://rmi-llc.net';
const ogImageUrl = new URL(ogImage, siteUrl).href;

const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${siteUrl}#business`,
  "name": companyNameFull,
  "description": description,
  "url": siteUrl,
  "telephone": phoneE164,
  "email": email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": address.street,
    "addressLocality": address.city,
    "addressRegion": address.state,
    "postalCode": address.zip,
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 42.2223,
    "longitude": -83.3630
  },
  "areaServed": [
    { "@type": "State", "name": "Michigan" },
    { "@type": "State", "name": "Ohio" },
    { "@type": "State", "name": "Indiana" },
    { "@type": "State", "name": "Illinois" },
    { "@type": "State", "name": "Wisconsin" }
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "07:00",
      "closes": "16:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      "opens": "00:00",
      "closes": "23:59",
      "description": "24/7 Emergency Response Available"
    }
  ],
  "logo": "https://rmi-llc.net/images/logo/rmi-logo-full.webp",
  "sameAs": [
    "https://www.linkedin.com/company/resource-mechanical-insulation",
    "https://www.facebook.com/ResourceMechanicalInsulation"
  ],
  "priceRange": "$$",
  "image": ogImageUrl,
  "knowsAbout": services.map(s => s.title),
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Mechanical Insulation Services",
    "itemListElement": services.map((s, i) => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": s.title,
        "description": s.description
      },
      "position": i + 1
    }))
  }
});

const serviceCatalogSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Resource Mechanical Insulation",
  "url": "https://rmi-llc.net",
  "logo": "https://rmi-llc.net/images/logo/rmi-logo-full.webp",
  "sameAs": [
    "https://www.linkedin.com/company/resource-mechanical-insulation",
    "https://www.facebook.com/ResourceMechanicalInsulation"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+12483795156",
    "contactType": "sales",
    "email": "info@rmi-llc.net",
    "availableLanguage": "English"
  },
  "foundingDate": "2021",
  "numberOfEmployees": {
    "@type": "QuantitativeValue",
    "minValue": 10,
    "maxValue": 50
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Mechanical Insulation Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Pipe Insulation",
          "description": "Commercial and industrial pipe insulation for HVAC, process piping, steam/condensate, and cryogenic systems"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Duct Insulation",
          "description": "Insulation for standard ductwork, grease duct, fume hood, generator exhaust, and boiler breeching"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Equipment Insulation",
          "description": "Insulation for tanks, vessels, and equipment including removable insulation blankets"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Pipe Support Fabrication",
          "description": "Custom pipe support fabrication and installation for industrial and commercial applications"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Field-Applied Jacketing",
          "description": "Aluminum, stainless steel, and PVC jacketing for outdoor and industrial insulation systems"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "24/7 Emergency Response",
          "description": "Round-the-clock emergency insulation repair and replacement services"
        }
      }
    ]
  }
});

const serviceSchemas = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Pipe Insulation",
    "provider": { "@type": "LocalBusiness", "name": companyNameFull },
    "areaServed": { "@type": "State", "name": "Michigan" },
    "description": "Commercial and industrial pipe insulation services including plumbing, HVAC, process piping, steam/condensate, and cryogenic systems."
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Duct Insulation",
    "provider": { "@type": "LocalBusiness", "name": companyNameFull },
    "areaServed": { "@type": "State", "name": "Michigan" },
    "description": "Insulation for standard ductwork, grease duct, fume hood, generator exhaust, and boiler breeching."
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Equipment Insulation",
    "provider": { "@type": "LocalBusiness", "name": companyNameFull },
    "areaServed": { "@type": "State", "name": "Michigan" },
    "description": "Insulation for tanks, vessels, and equipment including removable insulation blankets and cans."
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Field-Applied Jacketing",
    "provider": { "@type": "LocalBusiness", "name": companyNameFull },
    "areaServed": { "@type": "State", "name": "Michigan" },
    "description": "Aluminum, stainless steel, and PVC jacketing and lagging for outdoor and industrial insulation systems."
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Pipe Support Fabrication",
    "provider": { "@type": "LocalBusiness", "name": companyNameFull },
    "areaServed": { "@type": "State", "name": "Michigan" },
    "description": "Custom pipe support fabrication and installation for industrial and commercial applications."
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Emergency Insulation Response",
    "provider": { "@type": "LocalBusiness", "name": companyNameFull },
    "areaServed": { "@type": "State", "name": "Michigan" },
    "description": "24/7 emergency insulation repair and replacement services for urgent facility needs."
  }
]);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={author} />
    <meta name="robots" content="index, follow" />
    <meta name="language" content="English" />
    <meta name="revisit-after" content="7 days" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={fullTitle} />
    <meta property="og:site_name" content={companyName} />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={fullTitle} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />
    
    <!-- Preload LCP hero image (responsive) -->
    <link
      rel="preload"
      as="image"
      type="image/webp"
      href="/images/hero/hero-1.webp"
      imagesrcset="/images/hero/hero-1-480w.webp 480w, /images/hero/hero-1-960w.webp 960w, /images/hero/hero-1.webp 1920w"
      imagesizes="100vw"
      fetchpriority="high"
    />
    <link rel="preload" as="image" type="image/webp" href="/images/logo/rmi-logo-full.webp" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- Theme Color -->
    <meta name="theme-color" content="#171717" />
    <meta name="msapplication-TileColor" content="#171717" />

    <!-- Geo Meta Tags (Local SEO) -->
    <meta name="geo.region" content="US-MI" />
    <meta name="geo.placename" content="Romulus" />
    <meta name="geo.position" content="42.2223;-83.3630" />
    <meta name="ICBM" content="42.2223, -83.3630" />
    
    <!-- Google Tag Manager preconnect -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="preconnect" href="https://www.google-analytics.com" />

    <!-- Google Search Console (loads only when PUBLIC_GOOGLE_SITE_VERIFICATION is set) -->
    {import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION && (
      <meta name="google-site-verification" content={import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION} />
    )}

    <!-- Page load timestamp for intelligence collector -->
    <script is:inline>window.__rmiPageLoadTime = Date.now();</script>

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-7CW99VN6T3" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-7CW99VN6T3');
    </script>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={localBusinessSchema} />
    <script type="application/ld+json" set:html={serviceCatalogSchema} />
    <script type="application/ld+json" set:html={serviceSchemas} />
  </head>
  <body class="min-h-full overflow-x-hidden">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent-600 focus:text-white focus:rounded-md focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-neutral-900">
      Skip to main content
    </a>
    <noscript>
      <div style="background:#171717;color:#e5e5e5;text-align:center;padding:1rem;font-size:0.875rem;">
        This site works best with JavaScript enabled. Core content is still accessible without it.
      </div>
    </noscript>
    <Navbar />
    <main id="main-content">
      <slot />
    </main>
    <Analytics />
    <SpeedInsights />
  </body>
</html>

