---
import '../styles/global.css';
import AdminSidebar from '../components/admin/AdminSidebar.tsx';
import AdminHeader from '../components/admin/AdminHeader.tsx';
import { ToastContainer } from '../components/admin/Toast.tsx';

export const prerender = false;

interface Props {
  title: string;
  subtitle?: string;
  pageTitle?: string;
}

const { title, subtitle, pageTitle } = Astro.props;
const displayTitle = pageTitle ?? title;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{displayTitle} | RMI Admin</title>
    <meta name="theme-color" content="#0a0a0a" />
  </head>
  <body class="h-full bg-neutral-950 text-neutral-100">
    <AdminSidebar currentPath={currentPath} client:load />

    <div class="lg:ml-60 h-screen flex flex-col overflow-hidden">
      <AdminHeader title={title} subtitle={subtitle} client:load />

      <main class="flex-1 min-h-0 p-4 lg:p-6 overflow-y-auto">
        <slot />
      </main>
    </div>
    <ToastContainer client:load />
  </body>
</html>
